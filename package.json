{
  "name": "vue-js-es5-highlighter",
  "displayName": "Vue Highlighter for JS ES5 Syntax",
  "description": "Highlight JS ES5 Vue Code (Without Build Tools)",
  "version": "0.1.0",
  "publisher": "AlexandreJALLET",
  "author": {
    "name": "Alexandre JALLET"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mending-Electronics/Vue-Code-Highlighter-for-JS-ES5-Syntax"
  },
  
  "icon": "assets/extension-icon.png",
  "galleryBanner": {
    "color": "#42b883",
    "theme": "dark"
  },
  
  "badges": [
    {
      "url": "https://img.shields.io/badge/Vue-3-brightgreen.svg",
      "href": "https://vuejs.org/",
      "description": "Vue 3 compatible"
    }
  ],


  "engines": {
    "vscode": "^1.50.0"
  },
  "activationEvents": [
    "onLanguage:vue-withoutbuildtools"
  ],
  "main": "./out/src/extension.js",
  "devDependencies": {
    "@types/vscode": "^1.50.0",
    "typescript": "^4.0.0",
    "vscode-test": "^1.4.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "configuration": {
      "title": "Vue Highlighter for JS ES5 Syntax",
      "properties": {
        "vueHighlighter.suggest.showWords": {
          "type": "boolean",
          "default": false,
          "description": "Disable word-based suggestions to prioritize snippets",
          "scope": "language-overridable"
        },
        "vueHighlighter.tabCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable tab completion for snippets",
          "scope": "language-overridable"
        }
      }
    },
    "configurationDefaults": {
      "[vue-withoutbuildtools]": {
        "editor.suggest.showWords": false,
        "editor.tabCompletion": "on"
      }
    },
    "languages": [
      {
        "id": "vue-withoutbuildtools",
        "aliases": ["Vue (WithoutBuildTools)"],
        "extensions": [".vue"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/vue.svg",
          "dark": "./assets/vue.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "vue-withoutbuildtools",
        "scopeName": "source.js",
        "path": "./src/javascript/syntaxes/JavaScript.tmLanguage.json"
      },
      {
        "scopeName": "vue-withoutbuildtools.template-injection",
        "path": "./syntaxes/vue-withoutbuildtools.template-injection.tmLanguage.json",
        "injectTo": ["source.js"]
      }
    ],
    "snippets": [
      {
        "language": "vue-withoutbuildtools",
        "path": "./src/javascript/snippets/javascript.code-snippets"
      },
      {
        "language": "vue-withoutbuildtools",
        "path": "./src/html/snippets/html.code-snippets"
      },
      {
        "language": "vue-withoutbuildtools",
        "path": "./src/vue/snippets/vue.code-snippets"
      }
    ]


  }
}
